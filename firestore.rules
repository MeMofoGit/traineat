rules_version = '2';

// =====================================================================
// Firestore Security Rules — Fitness App
// =====================================================================
// Principio: multi-tenant estricto. Cada usuario solo lee/escribe su
// propio árbol `users/{uid}/**`. Colecciones públicas (OFF mirror y
// cache) son lectura autenticada, escritura solo desde Functions con
// Admin SDK (que se salta las rules).
//
// Shape de datos esperado (ver PROJECT_PLAN.md §4):
//   users/{uid}/data/plan                 — plan del usuario
//   users/{uid}/history/{sessionId}       — historial de sesiones
//   users/{uid}/customFoods/{foodId}      — productos personalizados
//   users/{uid}/profile/main              — entitlements + subscription
//   offProducts/{barcode}                 — mirror OFF (Fase 4)
//   productCache/{barcode}                — cache de fallbacks OFF API
//   _meta/{doc}                           — metadatos públicos
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // --- Per-user data ---
    // Escritura: solo el propietario.
    // Lectura: propietario + lectura pública del plan y customFoods
    // (para SharedView vía token — el token valida en cliente, los uid
    // son UUIDs no adivinables). En Fase 6+ migrar a Function callable.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /data/{docId} {
        allow read: if true;
        allow write: if isOwner(uid);
      }
      match /customFoods/{foodId} {
        allow read: if true;
        allow write: if isOwner(uid);
      }
      match /history/{sessionId} {
        allow read, write: if isOwner(uid);
      }
      match /shareTokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }
      match /profile/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // --- OFF mirror público (Fase 4): lectura autenticada, escritura solo Functions ---
    match /offProducts/{barcode} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // --- Cache de fallbacks API OFF: lectura autenticada, escritura solo Functions ---
    match /productCache/{barcode} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // --- Metadatos públicos (schemaVersion, offSync status, etc.) ---
    match /_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // --- Tokens compartidos (link nutricionista) ---
    // Lectura pública: SharedView los lee sin auth para validar expiración.
    // Escritura: solo el usuario autenticado (via servicio cliente que verifica uid).
    // Contenido: tokenId, uid, permissions, expiresAt — no datos sensibles.
    match /_shareTokens/{tokenId} {
      allow read: if true;
      allow write: if isAuthed();

      // Notas del nutricionista — escritura pública (el token valida en cliente)
      match /data/{docId} {
        allow read, write: if true;
      }
    }
  }
}
