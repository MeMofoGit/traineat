{
  "name": "functions",
  "version": "1.0.0",
  "description": "Cloud Functions for Fitness App",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  },
  "private": true
}
